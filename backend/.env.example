OPENAI_API_KEY=your_openai_api_key_here 
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.abc123.mongodb.net/?retryWrites=true&w=majority 
DB_NAME=orchestrix 
 
# LLM Provider: openai, ollama, or groq 
LLM_PROVIDER=groq 
GROQ_API_KEY=gsk_your_key_here 
GROQ_MODEL=llama-3.1-8b-instant 
 
OLLAMA_MODEL=llama3.2 
OLLAMA_BASE_URL=http://127.0.0.1:11434 
 
# Semantic Scholar API key (optional — removes rate limits) 
SEMANTIC_SCHOLAR_API_KEY=your_key_here 
 
# Agent URLs (Local development defaults) 
DISCOVERY_AGENT_URL=http://127.0.0.1:8001 
ANALYSIS_AGENT_URL=http://127.0.0.1:8002 
SUMMARY_AGENT_URL=http://127.0.0.1:8003 
CITATION_AGENT_URL=http://127.0.0.1:8004 
CHAT_AGENT_URL=http://127.0.0.1:8005 
SYNTHESIS_AGENT_URL=http://127.0.0.1:8006 
 
# Execution mode: single or multi 
EXECUTION_MODE=single 
